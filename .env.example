# ─────────────────────────────────────────────────────────────
# CRAZYWORK — environment (BOOT secrets only; runtime secrets live
# AES-encrypted in the DB and are edited in the admin panel).
# Copy to .env and fill in. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Database — local Postgres via docker-compose
DATABASE_URL="postgresql://crazywork:crazywork@localhost:5432/crazywork"

# Better Auth (session signing + base URL)
BETTER_AUTH_SECRET="change-me-to-a-random-32+-char-string"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (Better Auth loads these at init — boot-time, env only)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AES master key — encrypts all admin-entered runtime secrets.
# 32 bytes, base64. Generate: openssl rand -base64 32
# NEVER store this in the DB.
AES_MASTER_KEY=""

# Superadmin seed (used once by the seed script)
SUPERADMIN_EMAIL="owner@crazywork.my"
SUPERADMIN_PASSWORD="change-me-on-first-login"

# ─────────────────────────────────────────────────────────────
# The following are NOT env vars — they are entered in the admin
# panel (Settings → Integrations) and stored AES-256-GCM encrypted:
#   stripe_secret_key, stripe_publishable_key, stripe_webhook_secret
#   resend_api_key, resend_from_email
#   discord_webhook_url
# Cloudflare R2 creds may live here OR in the secrets store depending
# on how the human wires storage at launch:
#   R2_ACCOUNT_ID, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY,
#   R2_BUCKET, R2_PUBLIC_BASE_URL
# ─────────────────────────────────────────────────────────────
